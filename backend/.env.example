# --- Google OAuth (from Google Cloud Console > APIs & Services > Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match a redirect URI registered on the OAuth client.
# Local dev: http://localhost:8080/auth/gmail/callback
# Deployed:  https://<your-app>.fly.dev/auth/gmail/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/gmail/callback

# --- Secrets (generate with the commands in docs/SETUP.md) ---
# Fernet key used to encrypt Gmail OAuth tokens at rest in SQLite.
TOKEN_ENCRYPTION_KEY=
# Bearer token the CLI must present to call this API. Personal single-user secret.
MAILCHEF_API_TOKEN=

# --- LLM provider ---
OPENAI_API_KEY=
# Cheap/fast tier: bulk classification and screening.
CLASSIFIER_MODEL=gpt-4o-mini
# Strong tier: summaries, digest generation, complex query answering.
ANSWER_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
# Cosine-distance cutoff for semantic search (0=identical, 2=opposite).
# Starting point, not empirically tuned — tighten/loosen after real usage.
SEMANTIC_DISTANCE_THRESHOLD=0.45

# --- Storage paths (defaults fine for local dev; overridden on Fly via volume mount) ---
MAILCHEF_DATA_DIR=./data
# How many days of mail to backfill on the very first sync.
INITIAL_SYNC_DAYS=30

# --- Inbox actions ---
# How long a proposed action (archive/trash/bulk) stays confirmable before
# it expires and must be re-proposed.
ACTION_CONFIRMATION_TTL_MINUTES=10

# --- Digest schedule ---
DIGEST_HOUR=7
DIGEST_MINUTE=30
DIGEST_TIMEZONE=America/Los_Angeles
